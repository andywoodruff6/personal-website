---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('products', ({ data }) => import.meta.env.DEV || !data.draft);
entries.sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  const ao = a.data.order ?? 999;
  const bo = b.data.order ?? 999;
  if (ao !== bo) return ao - bo;
  return (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0);
});
---

<Base title="Products" description="Things I've made — physical and digital products, in one gallery.">
  <div class="products-intro">
    <h1>Products</h1>
    <p>Things I've made — physical goods and digital products, gathered in one place.</p>
  </div>

  <ul class="product-grid">
    {entries.map((p) => (
      <li class="product-card">
        <a href={`/products/${p.id}/`} class="product-card-link">
          <div class="product-card-media">
            {p.data.cover && <img src={p.data.cover} alt={p.data.title} loading="lazy" />}
            <span class={`product-badge product-badge-${p.data.type}`}>{p.data.type}</span>
          </div>
          <div class="product-card-body">
            <h2 class="product-card-title">{p.data.title}</h2>
            {p.data.description && <p class="product-card-desc">{p.data.description}</p>}
            <div class="product-card-meta">
              {p.data.price && <span class="product-price">{p.data.price}</span>}
              {p.data.status && <span class="product-status">{p.data.status}</span>}
            </div>
          </div>
        </a>
      </li>
    ))}
  </ul>
</Base>

<style>
  .products-intro {
    margin-bottom: 2rem;
  }
  .products-intro p {
    color: var(--color-muted);
    max-width: var(--measure);
  }

  .product-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .product-card {
    margin: 0;
  }

  .product-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 1px solid var(--color-rule);
    border-radius: 10px;
    overflow: hidden;
    background: var(--color-bg);
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .product-card-link:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
    box-shadow: 0 12px 28px rgba(16, 15, 15, 0.12);
  }

  .product-card-media {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--color-bg-2);
    overflow: hidden;
  }
  .product-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-badge {
    position: absolute;
    top: 0.6rem;
    left: 0.6rem;
    font-family: var(--font-mono);
    font-size: var(--fs-mono-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    color: var(--color-bg);
  }
  .product-badge-physical { background: var(--color-accent); }
  .product-badge-digital { background: var(--color-accent); }

  .product-card-body {
    padding: 1rem 1.1rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
  }
  .product-card-title {
    font-size: var(--fs-h3);
    margin: 0;
  }
  .product-card-desc {
    color: var(--color-muted);
    font-size: 0.92rem;
    margin: 0;
  }
  .product-card-meta {
    margin-top: auto;
    padding-top: 0.5rem;
    display: flex;
    gap: 0.75rem;
    align-items: baseline;
    font-family: var(--font-mono);
    font-size: var(--fs-mono-sm);
  }
  .product-price { font-weight: 600; }
  .product-status { color: var(--color-signal); }
</style>
