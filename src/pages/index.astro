---
import Base from '../layouts/Base.astro';
import Currently from '../components/Currently.astro';
import MissionMeter from '../components/MissionMeter.astro';
import { getCollection } from 'astro:content';

const sectionsToShow = ['ideas', 'predictions'] as const;

async function recentFor(section: typeof sectionsToShow[number], n: number) {
  const all = await getCollection(section, ({ data }) => import.meta.env.DEV || !data.draft);
  return all
    .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
    .slice(0, n);
}

const [predictions, ideas] = await Promise.all([
  recentFor('predictions', 4),
  recentFor('ideas', 4),
]);

function fmt(d?: Date) {
  return d ? d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '';
}
---

<Base title="Andy Woodruff" description="Andy Woodruff — Executive Director of OCME. Bringing self-sovereign identity to 100 million people by 2034.">
  <section class="home-intro">
    <h1>Andy Woodruff</h1>
    <p class="lede">
      I build products I believe in. Right now that's self-sovereign identity — I'm Executive
      Director of the <a href="https://ocmeco.org">Open Commercial Media Ecosystem</a>, working
      toward <a href="/2034/">100 million DIDs by 2034</a>.
    </p>
    <p>
      The identity layer is the substrate everything digital is built on. When life went digital,
      the most fundamental human asset — being a recognizable person — quietly became a permissioned
      service. 100 million DIDs is the tipping point: below it the work is fringe, above it network
      effects carry the next billion.
    </p>
  </section>

  <!-- <MissionMeter /> -->

  <Currently />

  <section class="home-section">
    <h2 class="section-label"><span class="section-number">01</span> Predictions</h2>
    <ul class="post-list">
      {predictions.map((p) => (
        <li>
          <a class="post-list-title" href={`/predictions/${p.id}/`}>{p.data.title}</a>
          <span class="post-list-meta">{fmt(p.data.date)}</span>
          {p.data.description && <p class="post-list-desc">{p.data.description}</p>}
        </li>
      ))}
    </ul>
  </section>

  <section class="home-section">
    <h2 class="section-label"><span class="section-number">02</span> Ideas</h2>
    <ul class="post-list">
      {ideas.map((p) => (
        <li>
          <a class="post-list-title" href={`/ideas/${p.id}/`}>{p.data.title}</a>
          <span class="post-list-meta">{fmt(p.data.date)}</span>
          {p.data.description && <p class="post-list-desc">{p.data.description}</p>}
        </li>
      ))}
    </ul>
  </section>

  <section class="home-section">
    <h2 class="section-label"><span class="section-number">03</span> Newsletter</h2>
    <p>Subscribe to <a href="https://shiftingcurrent.substack.com">The Shifting Current</a> for essays on identity, agency, and the transition.</p>
    <div class="substack-embed">
      <iframe
        src="https://shiftingcurrent.substack.com/embed?transparent=1"
        title="Subscribe to The Shifting Current on Substack"
        loading="lazy"
        width="480"
        height="320"
      ></iframe>
    </div>
  </section>
</Base>

<style>
  .substack-embed {
    margin-top: 1rem;
    display: flex;
    justify-content: center;
  }
  .substack-embed iframe {
    border: 0;
    background: transparent;
    width: 100%;
    max-width: 480px;
    height: 320px;
    display: block;
  }
</style>
