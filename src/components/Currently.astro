---
const lastUpdated = '2026-07-02';
const items = [
  {
    label: 'shipping',
    value: 'OCME governance framework V1, <a href="https://cubicube.com/" rel="noopener">CubiCubes</a>',
  },
  { label: 'reading', value: 'The Art of Doing Science and Engineering (Hamming)<br>Leviathan Wakes (Corey)' },
  { label: 'building', value: '<a href="/projects/ekko-pai/">EKKO (my PAI)</a>, <a href="/mcp/">Custom MCP Servers</a>, <a href="/projects/project-halo/">Project Halo</a>' },
  { label: 'working with', value: 'teams building agent-native products' },
];
---
<aside class="currently" aria-label="Currently">
  <div class="currently-header">
    <span class="currently-tag">// currently</span>
    <span class="currently-date">{lastUpdated}</span>
  </div>
  <ul class="currently-list">
    {items.map((item) => (
      <li>
        <span class="currently-label">{item.label}</span>
        <span class="currently-value" set:html={item.value} />
      </li>
    ))}
  </ul>
</aside>
