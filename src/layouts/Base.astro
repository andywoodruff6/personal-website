---
import '../styles/global.css';
import BadgerLogo from '../components/BadgerLogo.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const siteTitle = 'Andy Woodruff';
const siteTagline =
  'Andy Woodruff — Executive Director of OCME. Writing on self-sovereign identity, creator-governed ecosystems, and the Human 3.0 transition.';
const newsletterName = 'The Shifting Current';
const author = siteTitle;
const fullTitle = title === siteTitle ? title : `${title} — ${siteTitle}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const resolvedOgImage = ogImage ? new URL(ogImage, Astro.site).toString() : undefined;
const resolvedDescription = description ?? siteTagline;
const siteUrl = Astro.site?.toString() ?? 'https://andywoodruff.net/';
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Andy Woodruff',
  url: siteUrl,
  jobTitle: 'Executive Director, Open Commercial Media Ecosystem',
  worksFor: {
    '@type': 'Organization',
    name: 'Open Commercial Media Ecosystem',
    url: 'https://ocmeco.org',
  },
  image: new URL('/images/andy-soulscape.png', siteUrl).toString(),
  sameAs: ['https://ocmeco.org', 'https://shiftingcurrent.substack.com'],
};

const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: siteTitle,
  url: siteUrl,
  description: siteTagline,
  author: { '@type': 'Person', name: 'Andy Woodruff', url: siteUrl },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          document.documentElement.dataset.theme = saved || 'light';
        } catch (_) {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
    <title>{fullTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:url" content={canonicalURL} />
    {resolvedOgImage && <meta property="og:image" content={resolvedOgImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    {resolvedOgImage && <meta name="twitter:image" content={resolvedOgImage} />}

    <script is:inline type="application/ld+json" set:html={JSON.stringify(personJsonLd)} />
    {isHome && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
    )}

    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.bunny.net/css?family=ibm-plex-mono:400,500,600|ibm-plex-sans:400,400i,500,600,700&display=swap"
    />

    <link rel="alternate" type="application/rss+xml" title={siteTitle} href="/rss.xml" />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav">
        <div class="nav-top">
        <a href="/" class="brand">
          <BadgerLogo size={36} class="brand-mark" />
          <span class="brand-text">
            Andy Woodruff
            <span class="brand-role">Executive Director · OCME</span>
          </span>
        </a>
        <button
          type="button"
          class="nav-toggle"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="primary-nav"
          data-nav-toggle
        >
          <svg class="nav-toggle-icon nav-toggle-icon-open" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M3 6h18M3 12h18M3 18h18" />
          </svg>
          <svg class="nav-toggle-icon nav-toggle-icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M5 5l14 14M19 5l-14 14" />
          </svg>
        </button>
        <ThemeToggle />
        </div>
        <ul id="primary-nav">
          <li><a href="/2034/">2034</a></li>
          <li><a href="/mcp/">MCP</a></li>
          <li><a href="/themes/">Themes</a></li>
          <li><a href="/projects/">Projects</a></li>
          <li><a href="/products/">Products</a></li>
          <li><a href="/predictions/">Predictions</a></li>
          <li><a href="/ideas/">Ideas</a></li>
          <li><a href="/curation/">Curation</a></li>
          <li><a href="/speaking/">Speaking</a></li>
          <li><a href="/about/">About</a></li>
        </ul>
      </nav>
    </header>
    <script is:inline>
      (function () {
        const btn = document.querySelector('[data-nav-toggle]');
        if (!btn) return;
        btn.addEventListener('click', () => {
          const open = document.body.toggleAttribute('data-nav-open');
          btn.setAttribute('aria-expanded', open ? 'true' : 'false');
        });
        document.querySelectorAll('#primary-nav a').forEach((a) => {
          a.addEventListener('click', () => {
            document.body.removeAttribute('data-nav-open');
            btn.setAttribute('aria-expanded', 'false');
          });
        });
      })();
    </script>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-inner">
        <p class="footer-line">
          <strong>{author}</strong>
          <a class="footer-subscribe" href="https://shiftingcurrent.substack.com" rel="noopener">
            Subscribe — {newsletterName} →
          </a>
          <a href="/archives/">Archives</a>
          <a href="/connect/">Connect</a>
          <a href="/rss.xml">RSS</a>
        </p>
        <p class="footer-copyright">
          © {new Date().getFullYear()} {author}
        </p>
      </div>
    </footer>
  </body>
</html>
